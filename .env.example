# passbox 环境变量模板
# 复制为 .env.local 并填入真实值（.env.local 不入库）

# PostgreSQL 连接串（开发库）
DATABASE_URL="postgresql://user:password@localhost:5432/passbox"

# JWT 会话签名密钥（生产环境务必使用高强度随机串，如 openssl rand -base64 32）
JWT_SECRET="dev-jwt-secret-change-me-in-production"

# 测试库连接串（仅测试用）
# DATABASE_URL_TEST="postgresql://user:password@localhost:5432/passbox_test"
