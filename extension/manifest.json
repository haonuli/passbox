{
  "manifest_version": 3,
  "name": "PassBox",
  "version": "1.0.0",
  "description": "PassBox 密码管理器 - 自动填充与保存",
  "permissions": ["storage", "activeTab", "scripting", "cookies", "notifications", "alarms"],
  "host_permissions": ["http://localhost:3000/*"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "PassBox"
  },
  "icons": {
    "16": "src/popup/icon-16.png",
    "48": "src/popup/icon-48.png",
    "128": "src/popup/icon-128.png"
  }
}
